# Recommended for most uses
DATABASE_URL=sslmode=

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=

# Parameters for constructing your own connection string
PGHOST=
PGHOST_UNPOOLED=-restless-sun-a5seqxog.us-east-2.aws.neon.tech
PGUSER=
PGDATABASE=
PGPASSWORD=

# Parameters for Vercel Postgres Templates
POSTGRES_URL=sslmode=require
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
JWT_SECRET=
# Cliente HTTP (browser): base da API Nest (sem barra final)
NEXT_PUBLIC_API_BASE_URL=https://rfinance-api.onrender.com
# Kubb / codegen: JSON OpenAPI (deploy Render expõe em /docs-json)
OPENAPI_SPEC_URL=https://rfinance-api.onrender.com/docs-json