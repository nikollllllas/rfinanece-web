  "info": {
    "title": "RFinance API",
    "description": "API versionada para gestão financeira",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@rfinance.local"
          },
          "password": {
            "type": "string",
            "example": "Admin@123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Alimentação"
          },
          "color": {
            "type": "string",
            "example": "#22C55E"
          },
          "icon": {
            "type": "string",
            "example": "food"
          },
          "type": {
            "type": "string",
            "enum": [
              "GANHO",
              "GASTO",
              "AMBOS"
            ],
            "example": "GASTO"
          },
          "isDefault": {
            "type": "boolean",
            "example": false,
            "default": false
          }
        },
        "required": [
          "name",
          "color"
        ]
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Alimentação"
          },
          "color": {
            "type": "string",
            "example": "#22C55E"
          },
          "icon": {
            "type": "string",
            "example": "food"
          },
          "type": {
            "type": "string",
            "enum": [
              "GANHO",
              "GASTO",
              "AMBOS"
            ],
            "example": "GASTO"
          },
          "isDefault": {
            "type": "boolean",
            "example": false,
            "default": false
          }
        }
      },
      "CreateTransactionDto": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "example": "Supermercado"
          },
          "amount": {
            "type": "number",
            "example": 145.9
          },
          "date": {
            "type": "string",
            "example": "2026-03-31T00:00:00.000Z"
          },
          "type": {
            "type": "string",
            "enum": [
              "GANHO",
              "GASTO"
            ],
            "example": "GASTO"
          },
          "categoryId": {
            "type": "string",
            "example": "uuid-category"
          },
          "notes": {
            "type": "string",
            "example": "Compra mensal"
          },
          "tag": {
            "type": "string",
            "enum": [
              "FALTA",
              "PAGO",
              "DEVOLVER",
              "ECONOMIA"
            ],
            "nullable": true
          },
          "paymentMethod": {
            "type": "string",
            "enum": [
              "PIX",
              "DEBITO",
              "CREDITO"
            ],
            "nullable": true
          },
          "installmentCount": {
            "type": "number",
            "example": 3,
            "minimum": 2,
            "maximum": 12
          }
        },
        "required": [
          "description",
          "amount",
          "date",
          "type",
          "categoryId"
        ]
      },
      "UpdateTransactionDto": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "example": "Supermercado"
          },
          "amount": {
            "type": "number",
            "example": 145.9
          },
          "date": {
            "type": "string",
            "example": "2026-03-31T00:00:00.000Z"
          },
          "type": {
            "type": "string",
            "enum": [
              "GANHO",
              "GASTO"
            ],
            "example": "GASTO"
          },
          "categoryId": {
            "type": "string",
            "example": "uuid-category"
          },
          "notes": {
            "type": "string",
            "example": "Compra mensal"
          },
          "tag": {
            "type": "string",
            "enum": [
              "FALTA",
              "PAGO",
              "DEVOLVER",
              "ECONOMIA"
            ],
            "nullable": true
          },
          "paymentMethod": {
            "type": "string",
            "enum": [
              "PIX",
              "DEBITO",
              "CREDITO"
            ],
            "nullable": true
          },
          "installmentCount": {
            "type": "number",
            "example": 3,
            "minimum": 2,
            "maximum": 12
          }
        }
      },
      "CreateBudgetDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "example": 1200.5
          },
          "budgetMonth": {
            "type": "string",
            "example": "2026-03"
          },
          "categoryId": {
            "type": "string",
            "example": "uuid-category"
          }
        },
        "required": [
          "amount",
          "budgetMonth",
          "categoryId"
        ]
      },
      "ReplicateBudgetsDto": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "example": "replicate"
          },
          "targetMonth": {
            "type": "string",
            "example": "2026-04"
          }
        },
        "required": [
          "action",
          "targetMonth"
        ]
      },
      "UpdateBudgetDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "example": 1200.5
          },
          "budgetMonth": {
            "type": "string",
            "example": "2026-03"
          },
          "categoryId": {
            "type": "string",
            "example": "uuid-category"
          }
        }
      }
    }
  }
}